
<style>
  .stack_faq-section_item {
    background-color: {{ section.settings.background_color }};
    padding: 0px 0px 40px 0px !important;
    color: {{ section.settings.text_color }};
  }
  {% comment %} .stack_width_container.page-width {
    width: 100% !important;
  }  {% endcomment %}

  .stack_faq-layout{
    display:grid;
    grid-template-columns:1fr;
    gap:20px;
    align-items:center;
  }

  .stack_faq-layout.has-image{
    grid-template-columns:1fr 1fr;
    align-items: flex-start;
  }

  .stack_faq-image img{
    width:100%;
    height:auto;
    display:block;
  }

  @media screen and (max-width:768px){
    .stack_faq-layout.has-image{
      grid-template-columns:1fr;
    }
  }
  .stack_faq-title {
    color: {{ section.settings.heading_color }};
    text-align: {{ section.settings.heading_alignment }};
    font-size: {{ section.settings.heading_font_size_desktop }}px;
    font-weight: 700;
    text-transform: math-auto;
    font-family: 'Room205';
  }

   .stack_width_container {
      margin: 0 auto;
      {% comment %} width: 100%; {% endcomment %}
    }
    .stack_width_container.default {
      max-width: 1000px;
    }
    .stack_width_container.narrow {
      max-width: 800px;
    }
    .stack_width_container.wide {
      max-width: 1200px;
    }
    .stack_width_container.full {
      max-width: 100%;
    }
  @media screen and (max-width: 768px) {
    .stack_faq-title {
      font-size: {{ section.settings.heading_font_size_mobile }}px;
    }
  }

  .stack_faq-subtitle {
    color: {{ section.settings.text_color }};
    text-align: {{ section.settings.heading_alignment }};
    margin-bottom: 30px;
  }

  .stack_faq-item {
    {% unless section.settings.background_active %}
    border-bottom: 1px solid #ccc;
    {% endunless %}
    padding: 15px 0;
    cursor: pointer;
  }
  .stack_faq-question {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: {{ section.settings.faq_question_size_desktop }}px;
    font-weight: bold;
  }
  @media screen and (max-width: 768px) {
    .stack_faq-question {
      font-size: {{ section.settings.faq_question_size_mobile }}px;
    }
    .stack_faq-section_item {
      background-color: #ffffff;
      padding: 0px 0px 40px 0px;
      color: #333333;
    }
    .stack_faq-item.stack_background {
      padding: 12px !important;
    }
    .stack_faq-item.active .stack_faq-answer {
      height: max-content !important;
      max-height: max-content !important;
    }
  }
  .stack_faq-icon {
    width: 20px;
    height: 20px;
    fill: {{ section.settings.icon_color }};
    transition: transform 0.3s ease;
  }
  .stack_faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s ease, padding 0.3s ease;
    font-size: {{ section.settings.faq_answer_size }}px;
  }
  .stack_faq-item.active .stack_faq-answer {
    padding-top: 10px;
    max-height: 200px;
  }
  .stack_faq-item.stack_background {
    background-color: #f5f5f5;
    color: #231F20;
    border-radius: 8px;
    padding: 24px;
    margin-bottom: 8px;
  }
  .stack_faq-item.active.stack_background {
    background-color: #231F20 !important;
    color: #fff;
  }
  .stack_faq-item.active .stack_faq-icon.chevron {
    transform: rotate(180deg);
  }
</style>

<div class="stack_faq-wrapper">
  <h2 class="stack_faq-title">{{ section.settings.heading }}</h2>
  <div class="stack_faq-subtitle">{{ section.settings.subheading }}</div>

  {% comment %} <div class="stack_width_container {{ section.settings.max_width }}">
    {% for block in section.blocks %}
      <div class="stack_faq-item">
        <div class="stack_faq-question">
          <span>{{ block.settings.question }}</span>
          <span class="stack_faq-icon-wrapper">
            {% if section.settings.icon_style == 'chevron' %}
              <svg class="stack_faq-icon chevron" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M0 7.33l2.829-2.83 9.175 9.339 9.167-9.339 2.829 2.83-11.996 12.17z"/>
              </svg>
            {% else %}
              <svg class="stack_faq-icon plus" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M11 11H3.75a.75.75 0 0 0 0 1.5H11v7.25a.75.75 0 0 0 1.5 0V12.5h7.25a.75.75 0 0 0 0-1.5H12.5V3.75a.75.75 0 0 0-1.5 0V11Z"/>
              </svg>
              <svg
                class="stack_faq-icon minus"
                style="display: none;"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
              >
                <path d="M21 11.75a.75.75 0 0 0-.75-.75H3.75a.75.75 0 0 0 0 1.5h16.5a.75.75 0 0 0 .75-.75Z"/>
              </svg>
            {% endif %}
          </span>
        </div>
        <div class="stack_faq-answer">{{ block.settings.answer }}</div>
      </div>
    {% endfor %}
  </div> {% endcomment %}


  <div class="stack_width_container {% if section.settings.max_width == 'default' %}page-width {% else %}{{ section.settings.max_width }}{% endif %}">
  
  <div class="stack_faq-layout {% if section.settings.faq_image != blank %}has-image{% endif %}">

    {% if section.settings.faq_image != blank %}
      <div class="stack_faq-image">
        <img 
          src="{{ section.settings.faq_image | image_url: width: 800 }}"
          alt="FAQ Image"
        >
      </div>
    {% endif %}

    <div class="stack_faq-list">
      {% for block in section.blocks %}
        <div class="stack_faq-item {% if section.settings.first_open and forloop.first %}active{% endif %} {% if section.settings.background_active %}stack_background{% endif %}">
          <div class="stack_faq-question">
            <span>{{ block.settings.question }}</span>

            <span class="stack_faq-icon-wrapper">
              {% if section.settings.icon_style == 'chevron' %}
                <svg class="stack_faq-icon chevron" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                  <path d="M0 7.33l2.829-2.83 9.175 9.339 9.167-9.339 2.829 2.83-11.996 12.17z"/>
                </svg>
              {% else %}

                <svg class="stack_faq-icon plus" {% if section.settings.first_open and forloop.first %} style="display: none;" {% endif %} width="29" height="28" viewBox="0 0 29 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M21.3999 15.4H15.6932V21H12.8399V15.4H7.13329V12.6H12.8399V7H15.6932V12.6H21.3999M14.2666 0C12.3931 0 10.5379 0.362121 8.80699 1.06569C7.07609 1.76925 5.50336 2.80048 4.17858 4.1005C1.50308 6.72601 0 10.287 0 14C0 17.713 1.50308 21.274 4.17858 23.8995C5.50336 25.1995 7.07609 26.2307 8.80699 26.9343C10.5379 27.6379 12.3931 28 14.2666 28C18.0503 28 21.6791 26.525 24.3546 23.8995C27.0301 21.274 28.5332 17.713 28.5332 14C28.5332 12.1615 28.1641 10.341 27.4472 8.64243C26.7302 6.94387 25.6793 5.40053 24.3546 4.1005C23.0298 2.80048 21.4571 1.76925 19.7262 1.06569C17.9953 0.362121 16.1401 0 14.2666 0Z" fill="black"/>
                </svg>


                <svg class="stack_faq-icon minus" {% if forloop.first %} style="display: block;" {% endif %} style="display: none;" width="29" height="28" viewBox="0 0 29 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path fill-rule="evenodd" clip-rule="evenodd" d="M14.2666 0C10.4828 0 6.85409 1.475 4.17858 4.1005C1.50308 6.72601 0 10.287 0 14C0 17.713 1.50308 21.274 4.17858 23.8995C6.85409 26.525 10.4828 28 14.2666 28C18.0503 28 21.6791 26.525 24.3546 23.8995C27.0301 21.274 28.5332 17.713 28.5332 14C28.5332 10.287 27.0301 6.72601 24.3546 4.1005C21.6791 1.475 18.0503 0 14.2666 0ZM6.11425 13V15H22.4189V13H6.11425Z" fill="#F5F5F5"/>
                </svg>

              {% endif %}
            </span>

          </div>
          <div class="stack_faq-answer">{{ block.settings.answer }}</div>
        </div>
      {% endfor %}
    </div>

  </div>
</div>

</div>

<script>
  document.querySelectorAll('.stack_faq-item').forEach(item => {
    const question = item.querySelector('.stack_faq-question');
    const plusIcon = item.querySelector('.plus');
    const minusIcon = item.querySelector('.minus');

    question.addEventListener('click', () => {
      const isActive = item.classList.contains('active');

      item.classList.toggle('active');

      if (plusIcon && minusIcon) {
        if (!isActive) {
          plusIcon.style.display = 'none';
          minusIcon.style.display = 'inline';
        } else {
          plusIcon.style.display = 'inline';
          minusIcon.style.display = 'none';
        }
      }
    });
  });
</script>


{% schema %}
{
  "name": "Stack FAQ Section",
  "tag": "section",
  "class": "stack_faq-section_item",
  "settings": [
    {
      "type": "image_picker",
      "id": "faq_image",
      "label": "FAQ Image"
    },
    {
      "type": "checkbox",
      "id": "first_open",
      "label": "Keep first faq open",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "background_active",
      "label": "Add background color",
      "default": false
    },
    {
      "type": "select",
      "id": "max_width",
      "label": "Max Width Container",
      "options": [
        { "value": "default", "label": "Default" },
        { "value": "narrow", "label": "Narrow (800px)" },
        { "value": "wide", "label": "Wide (1200px)" },
        { "value": "full", "label": "Full Width" }
      ],
      "default": "default"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Got questions? We've got answers."
    },
    {
      "type": "select",
      "id": "icon_style",
      "label": "Toggle Icon Style",
      "options": [
        { "value": "chevron", "label": "Chevron" },
        { "value": "plusminus", "label": "Plus / Minus" }
      ],
      "default": "chevron"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_font_size_desktop",
      "label": "Heading Font Size (Desktop)",
      "min": 20,
      "max": 60,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "heading_font_size_mobile",
      "label": "Heading Font Size (Mobile)",
      "min": 16,
      "max": 40,
      "unit": "px",
      "default": 24
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "faq_question_size_desktop",
      "label": "FAQ Question Font Size (Desktop)",
      "min": 14,
      "max": 28,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "faq_question_size_mobile",
      "label": "FAQ Question Font Size (Mobile)",
      "min": 12,
      "max": 24,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "faq_answer_size",
      "label": "FAQ Answer Font Size",
      "min": 12,
      "max": 24,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Text Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "FAQ Text Color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon Color",
      "default": "#000000"
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "What is your return policy?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "We accept returns within 30 days of purchase with proof of receipt."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Stack FAQ"
    }
  ]
}
{% endschema %}
