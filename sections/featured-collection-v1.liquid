        {
          "label": "Gotham",
          "value": "Gotham"
        },
        {
          "label": "Gotham Bold",
          "value": "Gotham-bold"
        },
        {
          "label": "Eina03",
          "value": "Eina03"
        }
      ]
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content"
    },
    {
      "type": "select",
      "id": "content_font",
      "label": "Font",
      "default": "Gotham",
      "options": [
        {
          "label": "Room205",
          "value": "Room205"
        },
        {
          "label": "Gotham",
          "value": "Gotham"
        },
        {
          "label": "Gotham Bold",
          "value": "Gotham-bold"
        },
        {
          "label": "Eina03",
          "value": "Eina03"
        }
      ]
    },
    {
