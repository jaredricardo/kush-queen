{% style %}
  [data-section-id='{{ section.id }}'] {
    padding-top: {{ section.settings.ptop }}px;
    padding-bottom: {{ section.settings.pbottom }}px;
  }

  [data-section-id='{{ section.id }}'] .featured-collection-v1__heading {
    font-family: '{{ section.settings.heading_font }}';
  }

  [data-section-id='{{ section.id }}'] .featured-collection-v1__content * {
    font-family: '{{ section.settings.content_font }}';
  }

  [data-section-id='{{ section.id }}'] .collection-grid-item__title {
    font-family: '{{ section.settings.blocks_font }}';
  }

  [data-section-id="{{ section.id }}"] .featured-collection-v1__heading,
  [data-section-id="{{ section.id }}"] .featured-collection-v1__content * {
    color: {{ section.settings.section_text_color }} !important;
  }

  @media screen and (max-width: 768px) {
    [data-section-id='{{ section.id }}'] {
      padding-top: {{ section.settings.ptop_mobile }}px;
      padding-bottom: {{ section.settings.pbottom_mobile }}px;
    }
  }
{% endstyle %}

<div class="page-width" data-section-id="{{ section.id }}">
  {% if section.settings.heading != blank %}
    <h2 class="featured-collection-v1__heading">{{ section.settings.heading | escape }}</h2>
  {% endif %}

  {% if section.settings.content != blank %}
    <div class="rte featured-collection-v1__content">
      {{ section.settings.content }}
    </div>
  {% endif %}

  {% if section.settings.collection != blank %}
    <div class="swiper featured-collection-v1-swiper">
      {% assign products = section.settings.collection.products %}
      <div class="swiper-wrapper">
        {% for product in products limit: 8 %}
          <div class="swiper-slide">
            {% render 'product-card-grid-v2', product: product %}
          </div>
        {% endfor %}
      </div>
      <button class="btn btn--primary btn--primary-with-icon featured-collection-v1-slider__next hidden" type="button" aria-label="Next slide"></button>
      <div class="featured-collection-v1-slider__scrollbar"></div>
    </div>
  {% endif %}

  {%- liquid
    assign button_link = section.settings.collection.url
    if section.settings.button_link != blank
      assign button_link = section.settings.button_link
    endif
  -%}

  {%- if section.settings.show_button and section.settings.button_label != blank and button_link != blank -%}
    <a
      href="{{ button_link }}"
      class="btn btn--primary btn--primary-with-icon featured-collection-v1__button"
    >
      {{ section.settings.button_label | escape }}
    </a>
  {%- endif -%}
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    new Swiper('.featured-collection-v1-swiper', {
      slidesPerView: 2.3,
      spaceBetween: 14,
      navigation: {
        nextEl: '.featured-collection-v1-slider__next',
      },
      scrollbar: {
        el: '.featured-collection-v1-slider__scrollbar',
        draggable: true,
      },
      breakpoints: {
        768: {
          slidesPerView: 4,
          spaceBetween: 30,
        }
      },
    });
  });
</script>

{% schema %}
