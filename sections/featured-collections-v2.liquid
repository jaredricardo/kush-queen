{% style %}
  [data-section-id='{{ section.id }}'] {
    padding-top: {{ section.settings.ptop }}px;
    padding-bottom: {{ section.settings.pbottom }}px;
  }

  [data-section-id='{{ section.id }}'] .featured-collections-v2__heading {
    font-family: '{{ section.settings.heading_font }}';
  }

  [data-section-id='{{ section.id }}'] .featured-collections-v2__content * {
    font-family: '{{ section.settings.content_font }}';
  }

  [data-section-id='{{ section.id }}'] .collection-grid-item__title {
    font-family: '{{ section.settings.blocks_font }}';
  }

  [data-section-id="{{ section.id }}"] .featured-collections-v2__heading,
  [data-section-id="{{ section.id }}"] .featured-collections-v2__content * {
    color: {{ section.settings.section_text_color }} !important;
  }

  @media screen and (max-width: 768px) {
    [data-section-id='{{ section.id }}'] {
      padding-top: {{ section.settings.ptop_mobile }}px;
      padding-bottom: {{ section.settings.pbottom_mobile }}px;
    }
  }
{% endstyle %}

<div class="page-width" data-section-id="{{ section.id }}">
  {% if section.settings.heading != blank %}
    <h2 class="featured-collections-v2__heading">{{ section.settings.heading | escape }}</h2>
  {% endif %}

  {% if section.settings.content != blank %}
    <div class="rte featured-collections-v2__content">
      {{ section.settings.content }}
    </div>
  {% endif %}

  <div class="collection-grid">
    <ul class="grid grid--uniform" style="grid-template-columns: repeat({{ section.settings.grid }}, 1fr);">
      {% for block in section.blocks limit: section.blocks.size %}
        <li class="grid__item" {{ block.shopify_attributes }} onclick="window.location.href='{{ block.settings.collection.url }}'" >
          {% if block.settings.image %}
            {%- assign collection_image = block.settings.image -%}
          {% elsif block.settings.collection.image %}
            {%- assign collection_image = block.settings.collection.image -%}
          {% elsif block.settings.collection.products.first
            and block.settings.collection.products.first.images != empty
          %}
            {%- assign collection_image = block.settings.collection.products.first.featured_image -%}
          {% else %}
            {% assign collection_image = blank %}
          {% endif %}
          {% if block.settings.heading != blank %}
            {%- assign collection_title = block.settings.heading -%}
          {% elsif block.settings.collection.title != blank %}
            {%- assign collection_title = block.settings.collection.title -%}
          {% endif %}
          <div
            class="collection-grid-item__overlay box ratio-container lazyload js"
            data-bgset="{% include 'bgset', image: collection_image %}"
            data-sizes="auto"
            data-parent-fit="cover"
            style="background-image: url('{{ collection_image | img_url: '300x300' }}')"
          ></div>
          <noscript>
            <div
              class="collection-grid-item__overlay"
              style="background-image: url('{{ collection_image | img_url: '1024x1024' }}')"
            ></div>
          </noscript>
            <h3 class="collection-grid-item__title">{{ collection_title }}</h3>
        </li>
      {% endfor %}
    </ul>
  </div>

  {% if section.blocks.size == 0 %}
    {% render 'no-blocks' %}
  {% endif %}
</div>

{% schema %}
{
  "name": "Featured Collections V2",
  "class": "featured-collections-v2",
  "settings": [
    {
      "type": "header",
      "content": "Section Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Find Your Perfect High"
    },

    {
      "type": "select",
      "id": "heading_font",
      "label": "Heading Font",
      "default": "Room205",
      "options": [
        {
          "label": "Room205",
          "value": "Room205"
        },
        {
          "label": "Gotham",
          "value": "Gotham"
        },
        {
          "label": "Gotham Bold",
          "value": "Gotham-bold"
        },
        {
          "label": "Eina03",
          "value": "Eina03"
        }
      ]
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content"
    },
    {
      "type": "select",
      "id": "content_font",
      "label": "Font",
      "default": "Gotham",
      "options": [
        {
          "label": "Room205",
          "value": "Room205"
        },
        {
          "label": "Gotham",
          "value": "Gotham"
        },
        {
          "label": "Gotham Bold",
          "value": "Gotham-bold"
        },
        {
          "label": "Eina03",
          "value": "Eina03"
        }
      ]
    },
    {
      "type": "color",
      "id": "section_text_color",
      "label": "Section Text Color",
      "default": "#000000"
    },
    
    {
      "type": "header",
      "content": "Section Blocks"
    },
    {
      "type": "range",
      "id": "grid",
      "label": {
        "da": "Kollektioner pr. række",
        "de": "Kategorien per Reihe",
        "en": "Collections per row",
        "es": "Colecciones por fila",
        "fi": "Kokoelmia per rivi",
        "fr": "Collections par rangée",
        "hi": "प्रति पंक्ति कलेक्शन",
        "it": "Collezioni per riga",
        "ja": "行あたりのコレクション数",
        "ko": "열 별 컬렉션",
        "ms": "Koleksi setiap baris",
        "nb": "Samlinger per rad",
        "nl": "Collecties per rij",
        "pt-BR": "Coleções por linha",
        "pt-PT": "Coleções por linha",
        "sv": "Produktserier per rad",
        "th": "คอลเลกชันต่อแถว",
        "zh-CN": "每行产品系列数",
        "zh-TW": "每列商品系列數"
      },
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 3
    },
    {
      "type": "select",
      "id": "blocks_font",
      "label": "Font",
      "default": "Gotham",
      "options": [
        {
          "label": "Room205",
          "value": "Room205"
        },
        {
          "label": "Gotham",
          "value": "Gotham"
        },
        {
          "label": "Gotham Bold",
          "value": "Gotham-bold"
        },
        {
          "label": "Eina03",
          "value": "Eina03"
        }
      ]
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "ptop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "pbottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 0
    },
    {
      "type": "range",
      "id": "ptop_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "pbottom_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 0
    },
  ],
  "blocks": [
    {
      "name": "Collection",
      "type": "collection",
      "settings": [
         {
           "type": "collection",
           "id": "collection",
           "label": "Collection"
         },
         {
           "type": "text",
           "id": "heading",
           "label": "Heading"
         },
         {
           "type": "image_picker",
           "id": "image",
           "label": "Image"
         }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Collections V2"
    }
  ]
}
{% endschema %}
