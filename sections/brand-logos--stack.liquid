{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .site-breadcumb {
    display: none !important;
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }}">
  <div class="{% unless section.settings.full_width %}page-width{% endunless %}">
    <div class="stack_padding_stem section-{{ section.id }}-padding">
        <div class="logo-slider">
            <div class="logo-track">
            {% for block in section.blocks %}
                {% assign width_desktop = block.settings.logo_width_desktop | default: 120 %}
                {% assign height_desktop = block.settings.logo_height_desktop | default: 44 %}
                {% assign width_mobile = block.settings.logo_width_mobile | default: 100 %}
                {% assign height_mobile = block.settings.logo_height_mobile | default: 44 %}

                <div
                class="logo"
                style="
                    --logo-width-desktop: {{ width_desktop }}px;
                    --logo-height-desktop: {{ height_desktop }}px;
                    --logo-width-mobile: {{ width_mobile }}px;
                    --logo-height-mobile: {{ height_mobile }}px;
                "
                >
                {% if block.settings.logo_image %}
                    <img src="{{ block.settings.logo_image | img_url: 'master' }}" alt="Brand Logo">
                {% endif %}
                </div>
                {% if section.settings.separator_image %}
                <div class="separator">
                    <img src="{{ section.settings.separator_image | image_url: width: 40 }}" alt="Separator">
                </div>
                {% endif %}
            {% endfor %}

            {% for block in section.blocks %}
                {% assign width_desktop = block.settings.logo_width_desktop | default: 120 %}
                {% assign height_desktop = block.settings.logo_height_desktop | default: 44 %}
                {% assign width_mobile = block.settings.logo_width_mobile | default: 100 %}
                {% assign height_mobile = block.settings.logo_height_mobile | default: 44 %}

                <div
                class="logo mobile_logo_item"
                style="
                    --logo-width-desktop: {{ width_desktop }}px;
                    --logo-height-desktop: {{ height_desktop }}px;
                    --logo-width-mobile: {{ width_mobile }}px;
                    --logo-height-mobile: {{ height_mobile }}px;
                "
                >
                {% if block.settings.logo_image %}
                    <img src="{{ block.settings.logo_image | img_url: 'master' }}" alt="Brand Logo">
                {% endif %}
                </div>
                {% if section.settings.separator_image %}
                <div class="separator">
                    <img src="{{ section.settings.separator_image | image_url: width: 40 }}" alt="Separator">
                </div>
                {% endif %}
            {% endfor %}
            </div>
        </div>
    </div>
  </div>
</div>


<style>
  #shopify-section-{{ section.id }} {
    
  }

  .stack_padding_stem {
    width: 100%;
    margin: auto;
  }

  .logo-slider {
    overflow: hidden;
    padding: 20px 0;
    white-space: nowrap;
    height: 94px;
  }

  .logo-slider .logo-track {
    display: flex;
    align-items: center;
    gap: 40px;
    height: 100%;
  }

  .logo-slider .logo {
    display: flex;
    align-items: center;
    justify-content: center;
    width: var(--logo-width-desktop);
    height: var(--logo-height-desktop);
    flex-shrink: 0;
  }
  .logo-slider .logo.mobile_logo_item {
    display: none;
  }

  .logo-slider .logo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .logo-slider .separator {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 29px;
    width: 25px;
    flex-shrink: 0;
  }

  @media (min-width: 769px) {
    .logo-slider .logo-track {
      animation: none; 
      justify-content: space-between;
      gap: 50px; 
    }
  }

  @media (max-width: 768px) {
    .stack_padding_stem {
      padding-left: 0;
      padding-right: 0;
    }

    .logo-slider {
      height: 65px;
    }

    .logo-slider .logo {
      width: var(--logo-width-mobile);
      height: var(--logo-height-mobile);
    }
    .logo-slider .logo.mobile_logo_item {
      display: flex;
    }

    .logo-slider .logo-track {
      animation: scroll {{ section.settings.speed }}s linear infinite;
    }

    @keyframes scroll {
      0% {
        transform: translateX(0%);
      }
      100% {
        transform: translateX(-50%);
      }
    }
  }
</style>


{% schema %}
{
  "name": "Brand Logos Carousel",
  "settings": [
    {
        "type": "checkbox",
        "id": "full_width",
        "label": "Make the carousel full width",
        "default": false
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll Speed (seconds)",
      "min": 5,
      "max": 60,
      "step": 1,
      "unit": "s",
      "default": 25
    },
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "header",
      "content": "Add your brand logos and a common separator image"
    },
    {
      "type": "image_picker",
      "id": "separator_image",
      "label": "Separator image (used between logos)",
      "info": "Recommended: SVG or small PNG"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    }, 
    {
      "type": "header",
      "content": "Paddings"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo_image",
          "label": "Brand Logo"
        },
        {
          "type": "range",
          "id": "logo_width_desktop",
          "label": "Logo width (desktop)",
          "min": 20,
          "max": 300,
          "step": 5,
          "unit": "px",
          "default": 120
        },
         {
          "type": "range",
          "id": "logo_height_desktop",
          "label": "Logo height (desktop)",
          "min": 20,
          "max": 200,
          "step": 5,
          "unit": "px",
          "default": 50
        },
        {
          "type": "range",
          "id": "logo_width_mobile",
          "label": "Logo width (mobile)",
          "min": 20,
          "max": 300,
          "step": 5,
          "unit": "px",
          "default": 100
        },
        {
          "type": "range",
          "id": "logo_height_mobile",
          "label": "Logo height (mobile)",
          "min": 20,
          "max": 200,
          "step": 5,
          "unit": "px",
          "default": 40
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand Logos Carousel",
      "category": "Custom"
    }
  ]
}
{% endschema %}