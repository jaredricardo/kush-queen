</style>

<script>
  (function() {
    'use strict';

    var SECTION_ID = {{ section_id | json }};
    var SECTION_NS = 'stack_fc_' + SECTION_ID;

    if (window[SECTION_NS + '_initialized']) return;
    window[SECTION_NS + '_initialized'] = true;

    function formatMoney(cents) {
      if (typeof Shopify !== 'undefined' && Shopify.formatMoney) {
        return Shopify.formatMoney(cents, '{{ shop.money_format }}');
      }
      return (cents / 100).toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
    }

    function getProductData(productId) {
      try {
        var el = document.querySelector(
          '#stack_section-' + SECTION_ID + ' .stack_product-json[data-product-id="' + productId + '"]'
        );
        if (el) return JSON.parse(el.textContent);
      } catch (e) {}
      return null;
    }

    function findVariant(product, selectedOptions) {
      return product.variants.find(function(v) {
        return (
          (v.option1 === selectedOptions[0] || selectedOptions[0] === undefined) &&
          (v.option2 === selectedOptions[1] || selectedOptions[1] === undefined) &&
          (v.option3 === selectedOptions[2] || selectedOptions[2] === undefined)
        );
      });
    }

    function updatePriceBlock(card, variant, sectionSettings) {
      if (!variant) return;

      var priceDiv = card.querySelector('.stack_card-price');
      if (!priceDiv) return;

      priceDiv.setAttribute('data-product-id', variant.id);
      card.setAttribute('data-product-id', variant.id);

      var currentEl = priceDiv.querySelector('.stack_price-current');
      var compareEl = priceDiv.querySelector('.stack_price-compare');
      var badgeEl   = priceDiv.querySelector('.stack_price-badge');

      if (currentEl) {
        currentEl.innerHTML = '$' + formatMoney(variant.price);
      }

      if (variant.compare_at_price && variant.compare_at_price > variant.price) {
        if (!compareEl) {
          compareEl = document.createElement('span');
          compareEl.className = 'stack_price-compare';
          compareEl.style.cssText = 'color: var(--stack-color-compare-price); f ';
          priceDiv.appendChild(compareEl);
        }
        compareEl.innerHTML = '<s>$' + formatMoney(variant.compare_at_price) + '</s>';
        compareEl.style.display = '';

        var discountPct = Math.round((variant.compare_at_price - variant.price) / variant.compare_at_price * 100);
        if (!badgeEl) {
          badgeEl = document.createElement('span');
          badgeEl.className = 'stack_price-badge';
          badgeEl.style.cssText = 'background: var(--stack-color-label-sale); color: var(--stack-color-label-sale-text); f  display: inline-block; padding: 3px 8px; font-size: 11px; font-weight: 700; border-radius: 4px; letter-spacing: 0.05em;';
          priceDiv.appendChild(badgeEl);
        }
        badgeEl.textContent = discountPct + '% OFF';
        badgeEl.style.display = '';
      } else {
        if (compareEl) compareEl.style.display = 'none';
        if (badgeEl)   badgeEl.style.display   = 'none';
      }
    }

    function updateAtcButton(card, variant, atcText, soldOutText) {
      var btn = card.querySelector('.stack_atc-btn');
      if (!btn) return;
      btn.setAttribute('data-variant-id', variant ? variant.id : '');
      if (variant && variant.available) {
        btn.disabled = false;
        btn.removeAttribute('aria-disabled');
        btn.textContent = atcText || 'ADD TO CART';
      } else {
        btn.disabled = true;
        btn.setAttribute('aria-disabled', 'true');
        btn.textContent = soldOutText || 'SOLD OUT';
      }
    }

    document.addEventListener('change', function(e) {
        var btn = e.target.closest('.stack_option-btn[data-section-id="' + SECTION_ID + '"]');
        if (!btn) return;

        var productId   = btn.getAttribute('data-product-id');
        var optionIndex = parseInt(btn.getAttribute('data-option-index'), 10);
        var card        = btn.closest('.stack_product-card');
        if (!card || !productId) return;

        var product = getProductData(productId);
        if (!product) return;

        var siblings = card.querySelectorAll('.stack_option-btn[data-option-index="' + optionIndex + '"]');
        btn.classList.add('stack_option-btn--active');

        var selectedOptions = [];
        [0, 1, 2].forEach(function(i) {
            var selectEl = card.querySelector('select.stack_option-btn[data-option-index="' + i + '"]');
            selectedOptions[i] = selectEl ? selectEl.value : undefined;
        });

        var variant = findVariant(product, selectedOptions);
        if (variant) {
            updatePriceBlock(card, variant);
            updateAtcButton(
            card, variant,
            {{ section.settings.atc_text | default: 'ADD TO CART' | json }},
            {{ section.settings.sold_out_text | default: 'SOLD OUT' | json }}
            );
        }
    });

    {% comment %} document.addEventListener('click', function(e) {
      var btn = e.target.closest('.stack_option-btn[data-section-id="' + SECTION_ID + '"]');
      if (!btn) return;

      var productId   = btn.getAttribute('data-product-id');
      var optionIndex = parseInt(btn.getAttribute('data-option-index'), 10);
      var card        = btn.closest('.stack_product-card');
      if (!card || !productId) return;

      var product = getProductData(productId);
      if (!product) return;

      var siblings = card.querySelectorAll('.stack_option-btn[data-option-index="' + optionIndex + '"]');
      siblings.forEach(function(s) { s.classList.remove('stack_option-btn--active'); });
      btn.classList.add('stack_option-btn--active');

      var selectedOptions = [];
      [0, 1, 2].forEach(function(i) {
        var activeBtn = card.querySelector('.stack_option-btn[data-option-index="' + i + '"].stack_option-btn--active');
        selectedOptions[i] = activeBtn ? activeBtn.getAttribute('data-option-value') : undefined;
      });

      var variant = findVariant(product, selectedOptions);
      if (variant) {
        updatePriceBlock(card, variant);
        updateAtcButton(
          card, variant,
          {{ section.settings.atc_text | default: 'ADD TO CART' | json }},
          {{ section.settings.sold_out_text | default: 'SOLD OUT' | json }}
        );
      }
    }); {% endcomment %}

    document.addEventListener('click', function(e) {
      var btn = e.target.closest(
        '.stack_qty-btn[data-section-id="' + SECTION_ID + '"]'
      );
      if (!btn) return;

      var productId = btn.getAttribute('data-product-id');
      var card = btn.closest('.stack_product-card');
      if (!card) return;

      var qtyEl = card.querySelector('.stack_qty-val[data-product-id="' + productId + '"]');
      if (!qtyEl) return;

      var current = parseInt(qtyEl.textContent, 10) || 1;

      if (btn.classList.contains('stack_qty-minus')) {
        if (current > 1) qtyEl.textContent = current - 1;
      } else if (btn.classList.contains('stack_qty-plus')) {
        qtyEl.textContent = current + 1;
      }
    });

    document.addEventListener('click', function(e) {
      var btn = e.target.closest(
        '.stack_atc-btn[data-section-id="' + SECTION_ID + '"]'
      );
      if (!btn || btn.disabled) return;

      var variantId = btn.getAttribute('data-variant-id');
      if (!variantId) return;

      var card  = btn.closest('.stack_product-card');
      var qtyEl = card
        ? card.querySelector('.stack_qty-val[data-product-id="' + btn.getAttribute('data-product-id') + '"]')
        : null;
      var qty = qtyEl ? parseInt(qtyEl.textContent, 10) : 1;

      btn.classList.add('stack_loading');
      var originalText = btn.textContent;
      btn.textContent = '...';

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
        body: JSON.stringify({ id: variantId, quantity: qty })
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        btn.classList.remove('stack_loading');
        btn.classList.add('stack_success');
        btn.textContent = '✓ Added';

        var countEls = document.querySelectorAll('[data-cart-count], .cart-count, .cart__count, #CartCount, .header__cart-count');
        if (countEls.length) {
          fetch('/cart.js')
            .then(function(r) { return r.json(); })
            .then(function(cart) {
              countEls.forEach(function(el) { el.textContent = cart.item_count; });
            }).catch(function(){});
        }

        document.dispatchEvent(new CustomEvent('cart:refresh', { detail: { source: 'stack_featured_collection' } }));

        setTimeout(function() {
          btn.classList.remove('stack_success');
          btn.textContent = originalText;
        }, 2000);
      })
      .catch(function(err) {
        btn.classList.remove('stack_loading');
        btn.textContent = originalText;
        console.warn('[Stack FC] ATC error:', err);
      });
    });

  })();
</script>

