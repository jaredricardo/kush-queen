{% comment %}
  Stack Featured Collection - Premium Section
  DESIGNED BY @STACKWISEDEV
{% endcomment %}

{%- liquid
  assign section_id = section.id
  assign collection = collections[section.settings.collection]
  assign products_per_row_desktop = section.settings.columns_desktop
  assign products_per_row_mobile = section.settings.columns_mobile
  assign products_limit = section.settings.products_to_show
  assign alignment = section.settings.content_alignment
  assign heading_text = section.settings.heading
  assign sub_heading = section.settings.subheading
  assign show_vendor = section.settings.show_vendor
  assign show_labels = section.settings.show_labels
  assign show_metafields = section.settings.show_metafields
  assign show_quantity = section.settings.show_quantity
  assign show_rating = section.settings.show_ratings
  assign button_style = section.settings.button_style
  assign image_ratio = section.settings.image_ratio
  assign bestseller_tag = section.settings.bestseller_tag
  assign new_tag = section.settings.new_tag
  assign sale_tag = section.settings.hot_tag
-%}

<section
  class="stack_section stack_featured-collection"
  id="stack_section-{{ section_id }}"
  data-section-id="{{ section_id }}"
  style="
    {% comment %} --stack-font-heading: {{ section.settings.font_heading.family }}, {{ section.settings.font_heading.fallback_families }};
    --stack-font-body: {{ section.settings.font_body.family }}, {{ section.settings.font_body.fallback_families }}; {% endcomment %}
    --stack-font-heading-weight: {{ section.settings.font_heading.weight }};
    --stack-color-bg: {{ section.settings.section_bg }};
    --stack-color-card-bg: {{ section.settings.card_bg }};
    --stack-color-image-bg: {{ section.settings.image_bg }};
    --stack-color-heading: {{ section.settings.heading_color }};
    --stack-color-text: {{ section.settings.text_color }};
    --stack-color-price: {{ section.settings.price_color }};
    --stack-color-compare-price: {{ section.settings.compare_price_color }};
    --stack-color-btn-bg: {{ section.settings.btn_bg }};
    --stack-color-btn-text: {{ section.settings.btn_text_color }};
    --stack-color-btn-bg-hover: {{ section.settings.btn_bg_hover }};
    --stack-color-btn-text-hover: {{ section.settings.btn_text_hover_color }};
    --stack-color-label-sale: {{ section.settings.label_sale_bg }};
    --stack-color-label-sale-text: {{ section.settings.label_sale_text }};
    --stack-color-label-new: {{ section.settings.label_new_bg }};
    --stack-color-label-new-text: {{ section.settings.label_new_text }};
    --stack-color-label-best: {{ section.settings.label_best_bg }};
    --stack-color-label-best-text: {{ section.settings.label_best_text }};
    --stack-color-meta: {{ section.settings.metafield_badge_bg }};
    --stack-color-meta-text: {{ section.settings.metafield_badge_text }};
    --stack-color-star: {{ section.settings.star_color }};
    --stack-color-card-border: {{ section.settings.card_border_color }};
    --stack-card-border-width: {{ section.settings.card_border_width }}px;
    --stack-card-radius-desktop: {{ section.settings.card_radius_desktop }}px;
    --stack-card-radius-mobile: {{ section.settings.card_radius_mobile }}px;
    --stack-image-radius-desktop: {{ section.settings.image_radius_desktop }}px;
    --stack-image-radius-mobile: {{ section.settings.image_radius_mobile }}px;
    --stack-btn-radius: {{ section.settings.button_radius }}px;
    --stack-padding-card-desktop: {{ section.settings.card_padding_desktop }}px;
    --stack-padding-card-mobile: {{ section.settings.card_padding_mobile }}px;
    --stack-columns-desktop: {{ products_per_row_desktop }};
    --stack-columns-mobile: {{ products_per_row_mobile }};
    --stack-section-padding-top: {{ section.settings.padding_top }}px;
    --stack-section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --stack-heading-size-desktop: {{ section.settings.heading_size_desktop }}px;
    --stack-heading-size-mobile: {{ section.settings.heading_size_mobile }}px;
    background-color: var(--stack-color-bg);
    padding-top: var(--stack-section-padding-top);
    padding-bottom: var(--stack-section-padding-bottom);
  ">
  {%- if heading_text != blank or sub_heading != blank -%}
    <div class="stack_section-header stack_text-{{ alignment }}">
      <div class="stack_container page-width">
        {%- if heading_text != blank -%}
          <h2
            class="stack_section-heading"
            style="font-weight: var(--stack-font-heading-weight); color: var(--stack-color-heading); font-size: var(--stack-heading-size-desktop);"
          >
            {{ heading_text | escape }}
          </h2>
        {%- endif -%}
        {%- if sub_heading != blank -%}
          <p
            class="stack_section-subheading"
            style="color: var(--stack-color-text);"
          >
            {{ sub_heading | escape }}
          </p>
        {%- endif -%}
        {%- if section.settings.show_view_all and collection != blank -%}
          <a
            href="{{ collection.url }}"
            class="stack_view-all"
            style="color: var(--stack-color-btn-bg);"
          >
            {{ section.settings.view_all_text | default: 'View All' }}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

  <div class="stack_container page-width">
    <div class="stack_products-grid">
      {%- if collection != blank and collection.products.size > 0 -%}
        {%- for product in collection.products limit: products_limit -%}
          {%- liquid
            assign first_image = product.featured_image
            assign second_image = product.images[1]
            assign current_variant = product.selected_or_first_available_variant
            assign show_bestseller = false
            assign show_new = false
            assign show_sale = false
            if product.tags contains bestseller_tag and bestseller_tag != blank
              assign show_bestseller = true
            endif
            if product.tags contains new_tag and new_tag != blank
              assign show_new = true
            endif
            if product.compare_at_price > product.price
              assign show_sale = true
              assign discount = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price
            endif
          -%}

          <div
            class="stack_product-card"
            data-product-id="{{ product.id }}"
            data-product-handle="{{ product.handle }}"
            data-section-id="{{ section_id }}"
            style="padding: var(--stack-padding-card-desktop);"
          >
            <div class="stack_card-image-wrap stack_ratio-{{ image_ratio }}">
              <a href="{{ product.url }}" class="stack_card-image-link" aria-label="{{ product.title | escape }}">
                {%- if first_image != blank -%}
                  <img
                    class="stack_card-img stack_img-primary"
                    src="{{ first_image | image_url: width: 800 }}"
                    srcset="{{ first_image | image_url: width: 400 }} 400w, {{ first_image | image_url: width: 800 }} 800w"
                    alt="{{ first_image.alt | default: product.title | escape }}"
                    width="{{ first_image.width }}"
                    height="{{ first_image.height }}"
                    loading="lazy"
                  >
                  {%- if second_image != blank and section.settings.hover_second_image -%}
                    <img
                      class="stack_card-img stack_img-secondary"
                      src="{{ second_image | image_url: width: 800 }}"
                      srcset="{{ second_image | image_url: width: 400 }} 400w, {{ second_image | image_url: width: 800 }} 800w"
                      alt="{{ second_image.alt | default: product.title | escape }}"
                      width="{{ second_image.width }}"
                      height="{{ second_image.height }}"
                      loading="lazy"
                    >
                  {%- else -%}
                    <img
                        class="stack_card-img stack_img-secondary"
                        src="{{ first_image | image_url: width: 800 }}"
                        srcset="{{ first_image | image_url: width: 400 }} 400w, {{ first_image | image_url: width: 800 }} 800w"
                        alt="{{ first_image.alt | default: product.title | escape }}"
                        width="{{ first_image.width }}"
                        height="{{ first_image.height }}"
                        loading="lazy"
                    >
                  {%- endif -%}
                {%- else -%}
                  <div class="stack_card-img-placeholder">
                    {{ 'product-1' | placeholder_svg_tag: 'stack_placeholder-svg' }}
                  </div>
                {%- endif -%}
              </a>

              {%- if show_labels -%}
                <div class="stack_card-labels">
                  {%- if show_bestseller -%}
                    <span
                      class="stack_label stack_label--best"
                      style="background: var(--stack-color-label-best); color: var(--stack-color-label-best-text); "
                    >
                      {{ section.settings.bestseller_label | default: 'Best Seller' }}
                    </span>
                  {%- endif -%}
                  {%- if show_new -%}
                    <span
                      class="stack_label stack_label--new"
                      style="background: var(--stack-color-label-new); color: var(--stack-color-label-new-text); "
                    >
                      {{ section.settings.new_label | default: 'New' }}
                    </span>
                  {%- endif -%}
                  {%- if show_sale -%}
                    <span
                      class="stack_label stack_label--sale"
                      style="background: var(--stack-color-label-sale); color: var(--stack-color-label-sale-text); "
                    >
                      {{ section.settings.sale_label | default: 'Sale' }}
                    </span>
                  {%- endif -%}
                </div>
              {%- endif -%}

              {%- if section.settings.show_quick_view -%}
                <div class="stack_quick-view-overlay">
                  <a
                    href="{{ product.url }}"
                    class="stack_quick-view-btn"
                    style=" color: var(--stack-color-btn-text); background: var(--stack-color-btn-bg);"
                  >
                    Quick View
                  </a>
                </div>
              {%- endif -%}
            </div>

            <div
              class="stack_card-body"
              style="text-align: {{ alignment }};"
            >
              
                {%- if show_metafields -%}
                <div class="stack_meta-badges">
                  {%- assign meta1_ns_key = section.settings.metafield_1 | split: '.' -%}
                  {%- assign meta2_ns_key = section.settings.metafield_2 | split: '.' -%}
                  {%- assign meta3_ns_key = section.settings.metafield_3 | split: '.' -%}

                  {%- if meta1_ns_key.size == 2 -%}
                    {%- assign mf1 = product.metafields[meta1_ns_key[0]][meta1_ns_key[1]] -%}
                    {%- if mf1 != blank -%}
                      <span
                        class="stack_meta-badge"
                        style="background: var(--stack-color-meta); color: var(--stack-color-meta-text); "
                      >
                        {%- if section.settings.metafield_1_label != blank -%}
                          {{ section.settings.metafield_1_label }}
                        {%- endif -%}
                        {{ mf1 }}
                      </span>
                    {%- endif -%}
                  {%- endif -%}

                  {%- if meta2_ns_key.size == 2 -%}
                    {%- assign mf2 = product.metafields[meta2_ns_key[0]][meta2_ns_key[1]] -%}
                    {%- if mf2 != blank -%}
                      <span
                        class="stack_meta-badge"
                        style="background: var(--stack-color-meta); color: var(--stack-color-meta-text); "
                      >
                        {%- if section.settings.metafield_2_label != blank -%}
                          {{ section.settings.metafield_2_label }}
                        {%- endif -%}
                        {{ mf2 }}
                      </span>
                    {%- endif -%}
                  {%- endif -%}

                  {%- if meta3_ns_key.size == 2 -%}
                    {%- assign mf3 = product.metafields[meta3_ns_key[0]][meta3_ns_key[1]] -%}
                    {%- if mf3 != blank -%}
                      <span
                        class="stack_meta-badge"
                        style="background: var(--stack-color-meta); color: var(--stack-color-meta-text); "
                      >
                        {%- if section.settings.metafield_3_label != blank -%}
                          {{ section.settings.metafield_3_label }}
                        {%- endif -%}
                        {{ mf3 }}
                      </span>
                    {%- endif -%}
                  {%- endif -%}
                </div>
              {%- endif -%}

              <h3
                class="stack_card-title"
                style=" color: var(--stack-color-heading);"
              >
                <a href="{{ product.url }}" style="color: inherit; text-decoration: none;">
                  {{- product.title | escape -}}
                </a>
              </h3>

              {%- if show_rating -%}
                <div class="stack_card-rating">
                  {%- if product.metafields.judgeme.widget != blank -%}
                    <span class="jdgm-widget jdgm-preview-badge" data-id="{{ product.id }}">
                      {{- product.metafields.judgeme.widget -}}
                    </span>
                  {%- elsif product.metafields.loox.avg_rating != blank -%}
                    <div
                      class="loox-rating"
                      data-id="{{ product.id }}"
                      data-rating="{{ product.metafields.loox.avg_rating }}"
                      data-raters="{{ product.metafields.loox.num_reviews }}"
                    ></div>
                  {%- elsif product.metafields.reviewscouk.total -%}
                    {% assign review_count = product.metafields.reviewscouk.total %}
                    <div class="stack_review-rating">
                      <div class="stack_stars" aria-label="5 out of 5 stars">
                        {% for i in (1..5) %}
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                          </svg>
                        {% endfor %}
                      </div>
                      <p class="stack_rating-count">({{ review_count }} REVIEWS)</p>
                    </div>
                  {%- else -%}
                    <div class="stack_dummy-rating" aria-label="5 out of 5 stars">
                      <div class="stack_stars" style="color: var(--stack-color-star);">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                        </svg>
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                        </svg>
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                        </svg>
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                        </svg>
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                        </svg>
                      </div>
                      <span
                        class="stack_rating-count"
                        style="color: var(--stack-color-heading); "
                        >(80 REVIEWS)</span
                      >
                    </div>
                  {%- endif -%}
                </div>
              {%- endif -%}

              {% if product.description != blank%}
                <span class="stack_small--description">{{ product.description | escape }}</span>
              {% endif %}

              {%- if show_vendor -%}
                <p
                  class="stack_card-vendor"
                  style="color: var(--stack-color-text); "
                >
                  {{ product.vendor }}
                </p>
              {%- endif -%}

              

              {%- if product.variants.size > 1 -%}
                <div class="stack_variant-selector">
                  {%- for option in product.options_with_values -%}
                    <div class="stack_option-group">
                        <div class="stack_option-btns">
                            <select 
                                class="stack_option-btn" 
                                data-option-index="{{ forloop.index0 }}" 
                                data-product-id="{{ product.id }}" 
                                data-section-id="{{ section_id }}"
                                style="border-radius: var(--stack-btn-radius); padding: 7px 10px;"
                            >
                                {%- for value in option.values -%}
                                <option 
                                    value="{{ value | escape }}" 
                                    data-option-value="{{ value | escape }}"
                                    {% if forloop.first %}selected{% endif %}
                                >
                                    {{ value }}
                                </option>
                                {%- endfor -%}
                            </select>
                        </div>
                      {% comment %} <div class="stack_option-btns">
                        {%- for value in option.values -%}
                          {%- assign variant_for_value = product.variants | where: 'option1', value | first -%}
                          <button
                            class="stack_option-btn {% if forloop.first %}stack_option-btn--active{% endif %}"
                            data-option-index="{{ forloop.parentloop.index0 }}"
                            data-option-value="{{ value | escape }}"
                            data-product-id="{{ product.id }}"
                            data-section-id="{{ section_id }}"
                            style=" border-radius: var(--stack-btn-radius);"
                          >
                            {{ value }}
                          </button>
                        {%- endfor -%}
                      </div> {% endcomment %}
                    </div>
                  {%- endfor -%}
                </div>
              {%- endif -%}

              <div
                class="stack_card-price"
                data-product-handle="{{ product.handle }}"
                data-product-id="{{ current_variant.id }}">
                <div class="price_container">
                    <span
                    class="stack_price-current"
                    style="color: var(--stack-color-price); "
                    >
                    {{ current_variant.price | money }}
                    </span>
                    {%- if current_variant.compare_at_price > current_variant.price -%}
                    <span
                        class="stack_price-compare"
                        style="color: var(--stack-color-compare-price); "
                    >
                        <s>{{ current_variant.compare_at_price | money }}</s>
                    </span>
                    {%- endif -%}
                </div>

                {%- if current_variant.compare_at_price > current_variant.price -%}
                  {%- if show_labels -%}
                    {%- assign discount_pct = current_variant.compare_at_price
                      | minus: current_variant.price
                      | times: 100
                      | divided_by: current_variant.compare_at_price
                    -%}
                    <span
                      class="stack_price-badge"
                      style="background: var(--stack-color-label-sale); color: var(--stack-color-label-sale-text); "
                    >
                      {{- discount_pct }}% OFF</span
                    >
                  {%- endif -%}
                {%- endif -%}
              </div>

              <div class="stack_card-actions">
                {%- if section.settings.button_style == 'atc' -%}
                  <div class="stack_atc-group">
                    {%- if show_quantity -%}
                      <div class="stack_qty-control" style="border-color: var(--stack-color-card-border);">
                        <button
                          class="stack_qty-btn stack_qty-minus"
                          data-product-id="{{ product.id }}"
                          data-section-id="{{ section_id }}"
                          aria-label="Decrease quantity"
                          style="color: var(--stack-color-heading); "
                        >
                          −
                        </button>
                        <span
                          class="stack_qty-val"
                          data-product-id="{{ product.id }}"
                          style="color: var(--stack-color-heading); "
                          >1</span
                        >
                        <button
                          class="stack_qty-btn stack_qty-plus"
                          data-product-id="{{ product.id }}"
                          data-section-id="{{ section_id }}"
                          aria-label="Increase quantity"
                          style="color: var(--stack-color-heading); "
                        >
                          +
                        </button>
                      </div>
                    {%- endif -%}
                    <button
                      class="stack_atc-btn"
                      data-product-id="{{ product.id }}"
                      data-variant-id="{{ current_variant.id }}"
                      data-section-id="{{ section_id }}"
                      {%- unless current_variant.available %}
                        disabled aria-disabled="true"
                      {%- endunless %}
                      style=" border-radius: var(--stack-btn-radius); background: var(--stack-color-btn-bg); color: var(--stack-color-btn-text);"
                    >
                      {%- if current_variant.available -%}
                        {{ section.settings.atc_text | default: 'ADD TO CART' }}
                      {%- else -%}
                        {{ section.settings.sold_out_text | default: 'SOLD OUT' }}
                      {%- endif -%}
                    </button>
                  </div>

                {%- elsif section.settings.button_style == 'link' -%}
                  <a
                    href="{{ product.url }}"
                    class="stack_link-btn"
                    style="f  border-radius: var(--stack-btn-radius); background: var(--stack-color-btn-bg); color: var(--stack-color-btn-text);"
                  >
                    {{ section.settings.link_btn_text | default: 'VIEW PRODUCT' }}
                  </a>

                {%- elsif section.settings.button_style == 'both' -%}
                  <div class="stack_atc-group">
                    {%- if show_quantity -%}
                      <div class="stack_qty-control" style="border-color: var(--stack-color-card-border);">
                        <button
                          class="stack_qty-btn stack_qty-minus"
                          data-product-id="{{ product.id }}"
                          data-section-id="{{ section_id }}"
                          aria-label="Decrease quantity"
                          style="color: var(--stack-color-text);"
                        >
                          −
                        </button>
                        <span
                          class="stack_qty-val"
                          data-product-id="{{ product.id }}"
                          style="color: var(--stack-color-text);"
                          >1</span
                        >
                        <button
                          class="stack_qty-btn stack_qty-plus"
                          data-product-id="{{ product.id }}"
                          data-section-id="{{ section_id }}"
                          aria-label="Increase quantity"
                          style="color: var(--stack-color-text);"
                        >
                          +
                        </button>
                      </div>
                    {%- endif -%}
                    <button
                      class="stack_atc-btn"
                      data-product-id="{{ product.id }}"
                      data-variant-id="{{ current_variant.id }}"
                      data-section-id="{{ section_id }}"
                      {%- unless current_variant.available %}
                        disabled aria-disabled="true"
                      {%- endunless %}
                      style="f  border-radius: var(--stack-btn-radius); background: var(--stack-color-btn-bg); color: var(--stack-color-btn-text);"
                    >
                      {%- if current_variant.available -%}
                        {{ section.settings.atc_text | default: 'ADD TO CART' }}
                      {%- else -%}
                        {{ section.settings.sold_out_text | default: 'SOLD OUT' }}
                      {%- endif -%}
                    </button>
                  </div>
                  <a
                    href="{{ product.url }}"
                    class="stack_link-btn stack_link-btn--outline"
                    style="f  border-radius: var(--stack-btn-radius); border-color: var(--stack-color-btn-bg); color: var(--stack-color-btn-bg);"
                  >
                    {{ section.settings.link_btn_text | default: 'VIEW PRODUCT' }}
                  </a>
                {%- endif -%}
              </div>
            </div>

            <script type="application/json" class="stack_product-json" data-product-id="{{ product.id }}">
              {
                "id": {{ product.id }},
                "handle": "{{ product.handle }}",
                "title": {{ product.title | json }},
                "variants": [
                  {%- for v in product.variants -%}
                  {
                    "id": {{ v.id }},
                    "title": {{ v.title | json }},
                    "price": {{ v.price }},
                    "compare_at_price": {{ v.compare_at_price | default: 'null' }},
                    "available": {{ v.available }},
                    "option1": {{ v.option1 | json }},
                    "option2": {{ v.option2 | json }},
                    "option3": {{ v.option3 | json }}
                  }{%- unless forloop.last %},{%- endunless -%}
                  {%- endfor -%}
                ]
              }
            </script>
          </div>
        {%- endfor -%}

      {%- else -%}
        <div
          class="stack_empty-collection"
          style="color: var(--stack-color-text); f "
        >
          <p>No products found in this collection.</p>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  #stack_section-{{ section_id }} {
    
  }

  #stack_section-{{ section_id }} .stack_container {
    {% comment %} max-width: 1400px;
    margin: 0 auto;
    padding: 0 24px; {% endcomment %}
  }

  .stack_small--description {
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;  
    overflow: hidden;
    font-family: "Gotham";
    font-weight: 400;
    font-style: Book;
