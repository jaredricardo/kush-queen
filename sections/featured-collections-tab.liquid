{% style %}
  [data-section-id='{{ section.id }}'] {
    padding-top: {{ section.settings.ptop }}px;
    padding-bottom: {{ section.settings.pbottom }}px;
  }

  [data-section-id='{{ section.id }}'] .featured-collections-tab__heading {
    font-family: '{{ section.settings.heading_font }}';
  }

  [data-section-id='{{ section.id }}'] .featured-collections-tab__content * {
    font-family: '{{ section.settings.content_font }}';
  }

  [data-section-id='{{ section.id }}'] .collection-grid-item__title {
    font-family: '{{ section.settings.blocks_font }}';
  }

  @media screen and (max-width: 768px) {
    [data-section-id='{{ section.id }}'] {
      padding-top: {{ section.settings.ptop_mobile }}px;
      padding-bottom: {{ section.settings.pbottom_mobile }}px;
    }
  }
{% endstyle %}

<div class="page-width" data-section-id="{{ section.id }}">
  {% if section.settings.heading != blank %}
    <h2 class="featured-collections-tab__heading">{{ section.settings.heading | escape }}</h2>
  {% endif %}

  {% if section.blocks.size > 0 %}
    <div class="mood-tabs" role="tablist" aria-label="Mood categories">
      {% for block in section.blocks %}
        <button
          class="mood-tab{% if forloop.first %} is-active{% endif %}"
          type="button"
          role="tab"
          aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
          tabindex="{% if forloop.first %}0{% else %}-1{% endif %}"
          data-mood="{{ block.settings.heading | downcase }}"
        >
          {{ block.settings.heading | escape }}
        </button>
      {% endfor %}
    </div>
  {% endif %}

  <div class="featured-collections-tab__content-container">
    {% for block in section.blocks %}
      <div
        class="featured-collections-tab__content-block{% if forloop.first %} is-active{% endif %}"
        aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
        tabindex="{% if forloop.first %}0{% else %}-1{% endif %}"
      >
        <div class="featured-collections-tab__content-block-content">
          {% if block.settings.heading != blank %}
            <h3 class="featured-collections-tab__content-heading hidden-mobile">
              {{ block.settings.heading | escape }}
            </h3>
          {% endif %}

          {% if block.settings.description != blank %}
            <div class="rte featured-collections-tab__content-description">
              {{ block.settings.description }}
            </div>
          {% endif %}

          {%- liquid
            assign button_link = block.settings.collection.url
            if block.settings.button_link != blank
              assign button_link = block.settings.button_link
            endif
          -%}

          {%- if block.settings.button_label != blank and button_link != blank -%}
            <a
              href="{{ button_link }}"
              class="btn btn--primary btn--primary-with-icon featured-collections-tab__button hidden-mobile"
            >
              {{ block.settings.button_label | escape }}
            </a>
          {%- endif -%}
        </div>

        {% if block.settings.collection != blank %}
          <div class="swiper featured-collections-tab-swiper">
            {% assign products = block.settings.collection.products %}
            <div class="swiper-wrapper">
              {% for product in products limit: 8 %}
                <div class="swiper-slide">
                  {% render 'product-card-grid-v2', product: product %}
                </div>
              {% endfor %}
            </div>
            <div class="featured-collections-tab-slider__scrollbar hidden-desktop"></div>
          </div>
        {% endif %}

        {%- liquid
          assign button_link = block.settings.collection.url
          if block.settings.button_link != blank
            assign button_link = block.settings.button_link
          endif
        -%}

        {%- if block.settings.button_label != blank and button_link != blank -%}
          <a
            href="{{ button_link }}"
            class="btn btn--primary btn--primary-with-icon featured-collections-tab__button hidden-desktop"
          >
            {{ block.settings.button_label | escape }}
          </a>
        {%- endif -%}
      </div>
    {% endfor %}
  </div>

  {% if section.blocks.size == 0 %}
    {% render 'no-blocks' %}
  {% endif %}
</div>

<script>
  const tabs = Array.from(document.querySelectorAll('.mood-tab'));
  const tabContents = Array.from(document.querySelectorAll('.featured-collections-tab__content-block'));

  tabContents.forEach((tabContent) => {
    const element = tabContent.querySelector('.featured-collections-tab-swiper');
    new Swiper(element, {
      slidesPerView: 2.4,
      spaceBetween: 15,
      scrollbar: {
        el: '.featured-collections-tab-slider__scrollbar',
        draggable: true,
      },
      breakpoints: {
        768: {
          slidesPerView: 3.5,
          spaceBetween: 30,
        },
      },
    });
  });

  function setActiveTab(nextTab, nextTabContent, shouldFocus = false) {
    tabs.forEach((tab) => {
      const active = tab === nextTab;
      tab.classList.toggle('is-active', active);
      tab.setAttribute('aria-selected', active ? 'true' : 'false');
      tab.setAttribute('tabindex', active ? '0' : '-1');
    });

    tabContents.forEach((tabContent) => {
      const active = tabContent === nextTabContent;
      tabContent.classList.toggle('is-active', active);
      tabContent.setAttribute('aria-selected', active ? 'true' : 'false');
      tabContent.setAttribute('tabindex', active ? '0' : '-1');
    });

    if (shouldFocus) {
      nextTab.focus();
    }
  }

  tabs.forEach((tab, index) => {
    tab.addEventListener('click', () => setActiveTab(tab, tabContents[index]));
    tab.addEventListener('keydown', (event) => {
      const currentIndex = tabs.indexOf(tab);
      let nextIndex = currentIndex;

      if (event.key === 'ArrowRight') nextIndex = (currentIndex + 1) % tabs.length;
      if (event.key === 'ArrowLeft') nextIndex = (currentIndex - 1 + tabs.length) % tabs.length;
      if (event.key === 'Home') nextIndex = 0;
      if (event.key === 'End') nextIndex = tabs.length - 1;

      if (nextIndex !== currentIndex) {
        event.preventDefault();
        setActiveTab(tabs[nextIndex], tabContents[nextIndex], true);
      }
    });
  });
</script>

